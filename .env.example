# ========================================
# 机场自动签到脚本 - 环境变量配置模板
# 使用方式：复制此文件为 .env 并填写真实值
# ========================================

# ----------------------------------------
# 必需配置
# ----------------------------------------

# 机场账号邮箱（用于登录 flzt.org）
# 示例格式：example@gmail.com
USER_EMAIL="your_email@example.com"

# 机场账号密码
# ⚠️ 请确保密码正确，否则登录会失败
USER_PASSWORD="your_password_here"

# ----------------------------------------
# 可选配置
# ----------------------------------------

# PushPlus 推送通知 Token
# 用于微信推送签到结果通知
# 获取方式：
#   1. 访问 https://www.pushplus.plus/
#   2. 登录后点击"一对一消息"
#   3. 复制 Token 填入下方
# 留空则禁用推送功能
PUSHPLUS_TOKEN="your_pushplus_token_or_leave_empty"
